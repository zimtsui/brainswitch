{{#each declarations}}
<verbatim:declaration name="{{{this.name}}}">
  <verbatim:description>{{{this.description}}}</verbatim:description>
    {{#each this.parameters}}
    <verbatim:parameter name="{{{this.name}}}">
        <verbatim:description>{{{this.description}}}</verbatim:description>
        <verbatim:mime-type>{{{this.mimeType}}}</verbatim:mime-type>
    </verbatim:parameter>
    {{/each}}
    <verbatim:response>
        <verbatim:description>{{{this.response.description}}}</verbatim:description>
        <verbatim:mime-type>{{{this.response.mimeType}}}</verbatim:mime-type>
    </verbatim:response>
</verbatim:declaration>
{{/each}}
